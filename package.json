{
  "name": "ajanraj-tanstack",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "preview:worker": "bun run build && wrangler --cwd .output dev",
    "deploy": "bun run build && wrangler --cwd .output deploy",
    "content:build": "content-collections build",
    "test": "vitest run",
    "typecheck": "bun run content:build && tsc --noEmit",
    "format": "oxfmt --write",
    "lint": "oxlint --type-aware --type-check",
    "check": "bun run content:build && oxlint --type-aware --type-check && oxfmt --check"
  },
  "dependencies": {
